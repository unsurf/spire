# ──────────────────────────────────────────────────────────────────
# Spire — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ──────────────────────────────────────────────────────────────────

# Database connection (required)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
# Docker Compose default: postgresql://spire:spirepassword@db:5432/spire?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/spire?schema=public"

# NextAuth / Auth.js secret (required)
# Used to sign session tokens and CSRF tokens.
# Generate a secure value with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"
AUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"

# Public URL of your Spire instance (required)
# Used by NextAuth for redirect URLs and CSRF protection.
# In Docker Compose: http://localhost:3000
# In production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"
