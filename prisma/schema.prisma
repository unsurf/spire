generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PayCycle {
  WEEKLY
  FORTNIGHTLY
  TWICE_MONTHLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum AccountCategory {
  CHEQUE
  SAVINGS
  HIGH_GROWTH
  EMERGENCY
  INVESTMENT
  CRYPTO
  ASSET
  OTHER
}

enum SplitType {
  PERCENTAGE
  FIXED
}

enum TradeType {
  BUY
  SELL
}

enum BillCycle {
  DAILY
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  QUARTERLY
  ANNUALLY
  ONE_TIME
}

enum BillCategory {
  LIVING_EXPENSES
  SUBSCRIPTIONS
}

enum BillSubcategory {
  // Living Expenses
  RENT
  ELECTRICITY
  WATER
  GAS
  INTERNET
  GROCERIES
  HOME_INSURANCE
  PHONE
  COUNCIL_RATES
  // Subscriptions
  SOCIAL
  STREAMING
  DATA_STORAGE
  TOOLS
  AI
  SHOPPING_DELIVERY
  // Shared
  OTHER
}

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  passwordHash       String
  country            String?
  currency           String?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())

  incomes  Income[]
  accounts Account[]
  bills    Bill[]
  goals    Goal[]
}

model Income {
  id        String   @id @default(cuid())
  userId    String
  name      String
  amount    Decimal  @db.Decimal(12, 2)
  cycle     PayCycle
  lastPaidAt DateTime?
  // payDay: day-of-week 0–6 (Mon=0) for WEEKLY/FORTNIGHTLY; day-of-month 1–31 for others
  payDay    Int?
  // payDay2: second day-of-month for TWICE_MONTHLY (e.g. 15 when payDay=1)
  payDay2   Int?
  createdAt DateTime @default(now())

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  splits AccountSplit[]
}

model Account {
  id               String          @id @default(cuid())
  userId           String
  name             String
  category         AccountCategory
  oracleEnabled    Boolean         @default(true)
  annualGrowthRate Float?
  coinId           String?
  coinSymbol       String?
  coinQuantity     Decimal?        @db.Decimal(18, 8)
  createdAt        DateTime        @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  splits         AccountSplit[]
  balanceEntries BalanceEntry[]
  bills          Bill[]
  trades         Trade[]
  goals          Goal[]
}

model Trade {
  id        String    @id @default(cuid())
  accountId String
  type      TradeType
  quantity  Decimal   @db.Decimal(18, 8)
  price     Decimal   @db.Decimal(12, 2)
  tradedAt  DateTime
  note      String?
  createdAt DateTime  @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model AccountSplit {
  id        String    @id @default(cuid())
  incomeId  String
  accountId String
  type      SplitType
  value     Decimal   @db.Decimal(12, 2)

  income  Income  @relation(fields: [incomeId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([incomeId, accountId])
}

model Bill {
  id          String           @id @default(cuid())
  userId      String
  name        String
  amount      Decimal?         @db.Decimal(12, 2)
  accountId   String?
  cycle       BillCycle
  startDate   DateTime
  category    BillCategory?
  subcategory BillSubcategory?
  createdAt   DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
}

model BalanceEntry {
  id         String   @id @default(cuid())
  accountId  String
  balance    Decimal  @db.Decimal(12, 2)
  note       String?
  recordedAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  name         String
  targetAmount Decimal   @db.Decimal(12, 2)
  accountId    String?
  deadline     DateTime?
  createdAt    DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
}
